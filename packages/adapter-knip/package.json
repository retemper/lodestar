{
  "name": "@retemper/lodestar-adapter-knip",
  "version": "0.0.0",
  "type": "module",
  "description": "Knip adapter for Lodestar — find unused exports, dependencies, and files via lodestar check",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lodestar": "lodestar check"
  },
  "dependencies": {
    "@retemper/lodestar-types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
