{
  "name": "@lodestar/eslint",
  "version": "0.0.0",
  "type": "module",
  "description": "ESLint adapter for Lodestar — bridge rules and config presets",
  "license": "MIT",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@lodestar/types": "workspace:*"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript-eslint": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "typescript-eslint": { "optional": true }
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "typescript-eslint": "^8.57.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "sideEffects": false,
  "publishConfig": { "access": "public" }
}
