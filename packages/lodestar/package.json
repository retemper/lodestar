{
  "name": "lodestar",
  "version": "0.0.0",
  "type": "module",
  "description": "Declare your architecture. Enforce it. Project-level rule engine for TypeScript.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lodestar": "lodestar check"
  },
  "dependencies": {
    "@retemper/types": "workspace:*",
    "@retemper/config": "workspace:*",
    "@retemper/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
