{
  "name": "@lodestar/prettier",
  "version": "0.0.0",
  "type": "module",
  "description": "Prettier config presets for Lodestar",
  "license": "MIT",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "sideEffects": false,
  "publishConfig": { "access": "public" }
}
