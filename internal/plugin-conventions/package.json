{
  "name": "@repo/plugin-conventions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Internal conventions plugin — code style rules enforced across the monorepo",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lodestar": "lodestar check"
  },
  "dependencies": {
    "@retemper/lodestar-types": "workspace:*"
  },
  "devDependencies": {
    "@retemper/lodestar-test-utils": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
