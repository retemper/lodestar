{
  "name": "@retemper/lodestar-plugin-structure",
  "version": "0.0.0",
  "type": "module",
  "description": "File system structure enforcement — directory existence, forbidden paths, and paired file validation",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lodestar": "lodestar check"
  },
  "dependencies": {
    "@retemper/lodestar-types": "workspace:*",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@retemper/lodestar-test-utils": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/retemper/lodestar",
    "directory": "plugins/structure"
  }
}
